# MikroTik RouterOS Connection Settings
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# MikroTik router IP address or hostname
MIKROTIK_HOST=192.168.88.1

# API port (default: 8728, SSL: 8729)
MIKROTIK_PORT=8728

# RouterOS login credentials
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=your_secure_password_here

# Enable SSL connection (true/false)
# If true, make sure MIKROTIK_PORT is set to 8729
MIKROTIK_USE_SSL=false
